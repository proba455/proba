{
  "functions": {
    "api/*.php": {
      "runtime": "@vercel/php@0.6.0",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "env": {
    "FIREBASE_API_KEY": "@firebase_api_key",
    "FIREBASE_PROJECT_ID": "@firebase_project_id"
  },
  "build": {
    "env": {
      "NODE_VERSION": "24"
    }
  }
}
